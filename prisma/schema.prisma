generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String          @id @default(cuid())
  clerkId   String          @unique
  email     String          @unique
  imageUrl  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  name      String?
  plan      Plan            @default(FREE)
  jobs      GenerationJob[]
  projects  Project[]
}

model Project {
  id          String          @id @default(cuid())
  title       String          @default("Untitled Project")
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  genre       String?
  language    String          @default("English")
  status      ProjectStatus   @default(DRAFT)
  userId      String
  duration    Int?
  outputVideo String?
  prompt      String?
  style       String?
  thumbnail   String?
  assets      Asset[]
  characters  Character[]
  exports     Export[]
  jobs        GenerationJob[]
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes      Scene[]
  scripts     Script[]
}

model Script {
  id        String   @id @default(cuid())
  title     String?
  content   String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Scene {
  id          String  @id @default(cuid())
  title       String?
  description String?
  order       Int
  prompt      String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Character {
  id          String  @id @default(cuid())
  name        String
  description String?
  appearance  String?
  voice       String?
  imageUrl    String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id        String    @id @default(cuid())
  type      AssetType
  name      String?
  url       String
  provider  String?
  metadata  Json?
  createdAt DateTime  @default(now())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GenerationJob {
  id          String    @id @default(cuid())
  type        String
  provider    String
  model       String?
  prompt      String?
  status      JobStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  projectId   String
  userId      String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Export {
  id          String       @id @default(cuid())
  format      String
  resolution  String?
  url         String?
  status      ExportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  completedAt DateTime?
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum Plan {
  FREE
  PRO
  STUDIO
}

enum ProjectStatus {
  DRAFT
  WRITING
  GENERATING
  EDITING
  COMPLETED
  RENDERING
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  MUSIC
  SUBTITLE
  DOCUMENT
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
