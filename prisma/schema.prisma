// ===================================================
// Generator
// ===================================================

generator client {
  provider = "prisma-client-js"
}

// ===================================================
// Datasource
// ===================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum Plan {
  FREE
  PRO
  STUDIO
}

enum ProjectStatus {
  DRAFT
  WRITING
  GENERATING
  EDITING
  RENDERING
  COMPLETED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  MUSIC
  SUBTITLE
  DOCUMENT
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ===================================================
// USER
// ===================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique

  email     String   @unique
  name      String?
  imageUrl  String?

  plan       Plan @default(FREE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  jobs     GenerationJob[]
}

// ===================================================
// PROJECT
// ===================================================

model Project {
  id          String @id @default(cuid())

  title       String @default("Untitled Project")

  description String?

  prompt      String?

  genre       String?

  style       String?

  language    String @default("English")

  duration    Int?

  thumbnail   String?

  outputVideo String?

  status ProjectStatus @default(DRAFT)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  scripts Script[]

  scenes Scene[]

  characters Character[]

  assets Asset[]

  jobs GenerationJob[]

  exports Export[]
}

// ===================================================
// SCRIPT
// ===================================================

model Script {
  id String @id @default(cuid())

  title String?

  content String @db.Text

  version Int @default(1)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ===================================================
// SCENE
// ===================================================

model Scene {
  id String @id @default(cuid())

  title String?

  description String? @db.Text

  order Int

  prompt String? @db.Text

  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ===================================================
// CHARACTER
// ===================================================

model Character {
  id String @id @default(cuid())

  name String

  description String? @db.Text

  appearance String? @db.Text

  voice String?

  imageUrl String?

  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ===================================================
// ASSET
// ===================================================

model Asset {
  id String @id @default(cuid())

  type AssetType

  name String?

  url String

  provider String?

  metadata Json?

  createdAt DateTime @default(now())

  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ===================================================
// AI GENERATION JOBS
// ===================================================

model GenerationJob {
  id String @id @default(cuid())

  type String

  provider String

  model String?

  prompt String? @db.Text

  status JobStatus @default(PENDING)

  startedAt DateTime?

  completedAt DateTime?

  error String? @db.Text

  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===================================================
// EXPORTS
// ===================================================

model Export {
  id String @id @default(cuid())

  format String

  resolution String?

  url String?

  status ExportStatus @default(PENDING)

  createdAt DateTime @default(now())

  completedAt DateTime?

  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}